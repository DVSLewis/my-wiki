=\\\"shivsakhuja echinstitute ethereumfndn AustinGriffiths cyrilXBT\\\"\\n    32|TIER3=\\\"aboutcircles GnosisDAO gnosischain safe gnosisguild cowswap kylearojas thedaofund chaskin22 etheconomiczone\\\"\\n    33|\\n    34|ALL_ACCOUNTS=\\\"$TIER1 $TIER2 $TIER3\\\"\\n    35|TOTAL_ACCOUNTS=$(echo \\\"$ALL_ACCOUNTS\\\" | wc -w | tr -d ' ')\\n    36|\\n    37|echo \\\"Accounts to scan: $TOTAL_ACCOUNTS\\\"\\n    38|\\n    39|# ---------------------------------------------------------------------------\\n    40|# Fetch RSS feeds via RSSHub\\n    41|# ---------------------------------------------------------------------------\\n    42|FEED_DIR=\\\"/tmp/argus-feeds-${DATE}\\\"\\n    43|mkdir -p \\\"$FEED_DIR\\\"\\n    44|\\n    45|fetch_feed() {\\n    46|    local handle=\\\"$1\\\"\\n    47|    local url=\\\"${RSSHUB_BASE}/${handle}\\\"\\n    48|    local out=\\\"${FEED_DIR}/${handle}.xml\\\"\\n    49|    \\n    50|    if curl -sf --max-time 15 --retry 2 \\\"$url\\\" -o \\\"$out\\\" 2>/dev/null; then\\n    51|        echo \\\"[OK] $handle\\\"\\n    52|    else\\n    53|        echo \\\"[SKIP] $handle — feed unavailable\\\"\\n    54|        echo \\\"\\\" > \\\"$out\\\"\\n    55|    fi\\n    56|}\\n    57|\\n    58|echo \\\"\\\"\\n    59|echo \\\"--- Fetching RSS feeds ---\\\"\\n    60|for handle in $ALL_ACCOUNTS; do\\n    61|    fetch_feed \\\"$handle\\\" &\\n    62|done\\n    63|wait\\n    64|echo \\\"Feeds fetched.\\\"\\n    65|\\n    66|# ---------------------------------------------------------------------------\\n    67|# Parse posts from RSS XML (extract titles + links, last 24h only)\\n    68|# ---------------------------------------------------------------------------\\n    69|POSTS_FILE=\\\"/tmp/argus-posts-${DATE}.txt\\\"\\n    70|> \\\"$POSTS_FILE\\\"\\n    71|\\n    72|parse_feed() {\\n    73|    local handle=\\\"$1\\\"\\n    74|    local feed=\\\"${FEED_DIR}/${handle}.xml\\\"\\n    75|    \\n    76|    if [ ! -s \\\"$feed\\\" ]; then\\n    77|        return\\n    78|    fi\\n    79|    \\n    80|    # Extract items: title, link, pubDate using python for reliability\\n    81|    python3 - <<PYEOF\\n    82|import xml.etree.ElementTree as ET\\n    83|import sys\\n    84|from datetime import datetime, timezone, timedelta\\n    85|\\n    86|handle = \\\"$handle\\\"\\n    87|feed_file = \\\"$feed\\\"\\n    88|cutoff = datetime.now(timezone.utc) - timedelta(hours=24)\\n    89|\\n    90|try:\\n    91|    tree = ET.parse(feed_file)\\n    92|    root = tree.getroot()\\n    93|    \\n    94|    # Handle both RSS and Atom formats\\n    95|    ns = {'atom': 'http://www.w3.org/2005/Atom'}\\n    96|    items = root.findall('.//item') or root.findall('.//atom:entry', ns)\\n    97|    \\n    98|    for item in items[:10]:  # cap at 10 per account\\n    99|        title_el = item.find('title') or item.find('atom:title', ns)\\n   100|        link_el = item.find('link') or item.find('atom:link', ns)\\n   101|        date_el = item.find('pubDate') or item.find('published') or item.find('atom:published', ns)\\n   102|        \\n   103|        title = title_el.text if title_el is not None else ''\\n   104|        link = link_el.text if link_el is not None else (link_el.get('href', '') if link_el is not None else '')\\n   105|        date_str = date_el.text if date_el is not None else ''\\n   106|        \\n   107|        if not title or len(title.strip()) < 5:\\n   108|            continue\\n   109|            \\n   110|        # Try to filter by recency — skip if older than 24h\\n   111|        # (be permissive if date parse fails)\\n   112|        try:\\n   113|            from email.utils import parsedate_to_datetime\\n   114|            pub_date = parsedate_to_datetime(date_str)\\n   115|            if pub_date < cutoff:\\n   116|                continue\\n   117|        except Exception:\\n   118|            pass  # keep item if date unparseable\\n   119|        \\n   120|        title = title.strip().replace('\\\\n', ' ')[:200]\\n   121|   